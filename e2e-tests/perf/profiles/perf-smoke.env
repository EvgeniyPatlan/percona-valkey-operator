# e2e-tests/perf/profiles/perf-smoke.env — nightly trend profile (arch §5).
# Small + fast: a single 3-shard cluster, ~60s benchmark window. Sourced by run-perf.sh.
# Goal: cheap trend detection in CI nightly, NOT a hard PR gate.

PROFILE_NAME=perf-smoke

# Topology
PERF_SHARDS=3
PERF_REPLICAS=1
# Scale phase disabled in smoke (throughput/latency + exporter-overhead only).
PERF_DO_SCALE=false
PERF_DO_EVICTION=true

# Benchmark sizing (kept small for ~60s on a laptop/CI runner)
BENCH_REQUESTS=200000
BENCH_CLIENTS=50
BENCH_PAYLOAD=64
BENCH_KEYSPACE=100000
BENCH_TESTS=SET,GET

# Run the benchmark with AND without the exporter sidecar to measure overhead.
PERF_COMPARE_EXPORTER=true
