# e2e-tests/perf/profiles/perf-scale.env — release-only scale profile (arch §5).
# Large + slow: scale-out 6→12 shards, large keyspace, full metric set (throughput,
# exporter overhead, rebalance throughput, scale-out latency, rolling-update window).
# Sourced by run-perf.sh. Release validation only — do NOT run on PRs.

PROFILE_NAME=perf-scale

# Topology — start at 6 shards, scale to 12 to measure rebalance + scale-out latency.
PERF_SHARDS=6
PERF_REPLICAS=1
PERF_SCALE_TO=12
PERF_DO_SCALE=true
PERF_DO_EVICTION=true
PERF_DO_ROLLING=true

# Benchmark sizing (larger keyspace + payload; longer measured window)
BENCH_REQUESTS=2000000
BENCH_CLIENTS=100
BENCH_PAYLOAD=256
BENCH_KEYSPACE=2000000
BENCH_TESTS=SET,GET

PERF_COMPARE_EXPORTER=true
